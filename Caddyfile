{$DOMAIN} {
    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-XSS-Protection "1; mode=block"
        -Server
    }

    # Enable gzip
    encode gzip

    # Redirect /admin and /app without trailing slash
    redir /admin /admin/ 308
    redir /app /app/ 308
    redir /m /m/ 308
    redir /my /my/ 308

    # Admin panel
    handle /admin/* {
        uri strip_prefix /admin
        reverse_proxy web:3001
    }

    # Mini-app
    handle /app/* {
        uri strip_prefix /app
        reverse_proxy frontend:3000
    }

    # Public master pages (no strip_prefix -- SPA receives full /m/... path)
    handle /m/* {
        reverse_proxy public:3002
    }

    # Client cabinet (no strip_prefix -- SPA receives full /my/... path)
    handle /my/* {
        reverse_proxy public:3002
    }

    # Static assets (Vite build output with base "/")
    handle /assets/* {
        reverse_proxy public:3002
    }

    # API
    handle /api/* {
        reverse_proxy api:8000
    }

    # Webhooks
    handle /webhook/* {
        reverse_proxy api:8000
    }

    # Default
    handle {
        reverse_proxy api:8000
    }
}
